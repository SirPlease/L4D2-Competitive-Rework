# Copy to scripts/l4d2-docker.env, chmod 600, then fill the private values.
# The deploy script also accepts L4D2_ENV_FILE=/path/to/file.

# Network
# Leave L4D2_SERVER_IP empty to detect the public IP automatically.
# Leave L4D2_BIND_IP empty to use the host's default-route source IP.
L4D2_SERVER_IP=
L4D2_BIND_IP=

# Server layout
L4D2_SERVER_COUNT=8
L4D2_GAME_PORTS="12001 12002 12003 12004 12005 12006 12007 12008"
L4D2_BACKEND_PORTS="12009 12010 12011 12012 12013 12014 12015 12016"
L4D2_CONTAINER_PREFIX=anne
L4D2_HOSTNAME_START_INDEX=27
L4D2_HOSTNAME_PREFIX="Anne Server #"

# Images and base container
L4D2_BASE_IMAGE_URL=docker.1panel.live/morzlee/l4d2:latest
L4D2_BASE_CONTAINER_NAME=l4d2base
L4D2_PROD_IMAGE_NAME=morzlee/l4d2:base

# Repository inside the base image/container
L4D2_GIT_DIR=/home/louis/CompetitiveWithAnne
L4D2_GIT_PROXY_URL=https://gh-proxy.org/https://github.com/fantasylidong/CompetitiveWithAnne.git

# Game runtime
L4D2_TIMEZONE=Asia/Shanghai
L4D2_MAP_UPLOAD_DIR=/map/uploads
L4D2_DEFAULT_MAP=c2m1_highway
L4D2_REGION=255
L4D2_PLUGIN=zone
L4D2_CLOUD=true

# Steam settings. Fill with your real values locally.
L4D2_STEAM_GROUP=CHANGE_ME
L4D2_STEAM_ADMIN=CHANGE_ME
L4D2_OPTIONAL_STEAM_ID=

# Database and RCON. Fill with your real values locally.
L4D2_MYSQL_HOST=CHANGE_ME
L4D2_MYSQL_PORT=12345
L4D2_MYSQL_USER=CHANGE_ME
L4D2_MYSQL_PASSWORD=CHANGE_ME
L4D2_RCON_PASSWORD=CHANGE_ME

# System install behavior
L4D2_SQPROXY_ENABLE=true
L4D2_ENABLE_EBPF=true
L4D2_APT_MIRROR=
L4D2_SQPROXY_VERSION=2.5.0
L4D2_SQPROXY_VENV=/opt/sqproxy/venv
L4D2_ASSUME_YES=0
L4D2_REMOVE_BASE_IMAGE=1

# A2S firewall. "auto" protects the configured game and backend ports.
# You can also use a range/list, for example: "20000:50000" or "12001,12002".
L4D2_A2S_FIREWALL_ENABLE=true
L4D2_A2S_FIREWALL_PORTS=auto
L4D2_A2S_PLAYER_RATE=15/second
L4D2_A2S_PLAYER_BURST=10
L4D2_A2S_INFO_RATE=15/second
L4D2_A2S_INFO_BURST=10
L4D2_A2S_RULES_RATE=10/second
L4D2_A2S_RULES_BURST=5
L4D2_A2S_OTHER_RATE=10/second
L4D2_A2S_OTHER_BURST=5
L4D2_A2S_BAN_SECONDS=60
L4D2_A2S_BAN_HITCOUNT=3
L4D2_A2S_HASH_EXPIRE_MS=60000
L4D2_A2S_LOG_LIMIT=5/min
