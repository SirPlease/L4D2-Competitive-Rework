# Copy to scripts/l4d2-docker.env, chmod 600, then fill the private values.
# The deploy script also accepts L4D2_ENV_FILE=/path/to/file.
# To migrate from an old management script, either run:
#   scripts/l4d2-docker.sh --legacy-config /path/to/old-manager.sh --status
# or set:
#   L4D2_LEGACY_ENV_FILE=/path/to/old-manager.sh

# Network
# Leave L4D2_SERVER_IP empty to detect the public IP automatically.
# Leave L4D2_BIND_IP empty to use the host's default-route source IP.
L4D2_SERVER_IP=
L4D2_BIND_IP=

# Server layout
L4D2_SERVER_COUNT=8
L4D2_GAME_PORTS="12001 12002 12003 12004 12005 12006 12007 12008"
L4D2_BACKEND_PORTS="12009 12010 12011 12012 12013 12014 12015 12016"
L4D2_CONTAINER_PREFIX=anne
L4D2_HOSTNAME_START_INDEX=27
L4D2_HOSTNAME_PREFIX="Anne Server #"

# Images and base container
L4D2_BASE_IMAGE_URL=docker.1panel.live/morzlee/l4d2:latest
L4D2_BASE_CONTAINER_NAME=l4d2base
L4D2_PROD_IMAGE_NAME=morzlee/l4d2:base

# Repository inside the base image/container
L4D2_GIT_DIR=/home/louis/CompetitiveWithAnne
L4D2_GIT_PROXY_URL=https://gh-proxy.org/https://github.com/fantasylidong/CompetitiveWithAnne.git

# Game runtime
L4D2_TIMEZONE=Asia/Shanghai
L4D2_MAP_UPLOAD_DIR=/map/uploads
L4D2_DEFAULT_MAP=c2m1_highway
L4D2_REGION=255
L4D2_PLUGIN=zone
L4D2_CLOUD=true

# Map uploader Docker
L4D2_MAP_UPLOADER_ENABLE=false
L4D2_MAP_UPLOADER_DIR=
L4D2_MAP_UPLOADER_IMAGE_NAME=docker.trygek.com/morzlee/vpk-uploader:latest
L4D2_MAP_UPLOADER_CONTAINER_NAME=vpk-uploader
L4D2_MAP_UPLOADER_BIND_IP=0.0.0.0
L4D2_MAP_UPLOADER_PORT=8080
L4D2_MAP_UPLOADER_DATA_DIR=/opt/vpk-uploader/data
L4D2_MAP_UPLOADER_RULES_FILE=
L4D2_MAP_UPLOADER_PUBLIC_BASE_URL=
L4D2_MAP_UPLOADER_APP_SECRET=CHANGE_ME
L4D2_MAP_UPLOADER_ADMIN_USER=admin
L4D2_MAP_UPLOADER_ADMIN_PASS=CHANGE_ME
L4D2_MAP_UPLOADER_MAX_UPLOAD_MB=1024
L4D2_MAP_UPLOADER_MAX_TOTAL_UPLOAD_MB=0
L4D2_MAP_UPLOADER_GUEST_TTL_HOURS=24

# Steam settings. Fill with your real values locally.
L4D2_STEAM_GROUP=CHANGE_ME
L4D2_STEAM_ADMIN=CHANGE_ME
L4D2_OPTIONAL_STEAM_ID=

# Database and RCON. Fill with your real values locally.
L4D2_MYSQL_HOST=CHANGE_ME
L4D2_MYSQL_PORT=12345
L4D2_MYSQL_USER=CHANGE_ME
L4D2_MYSQL_PASSWORD=CHANGE_ME
L4D2_RCON_PASSWORD=CHANGE_ME

# System install behavior
L4D2_APT_MIRROR=
L4D2_ASSUME_YES=0
L4D2_REMOVE_BASE_IMAGE=1
L4D2_REMOVE_RUNTIME_IMAGE=1
L4D2_LEGACY_ENV_FILE=

# A2S Go proxy
L4D2_GO_PROXY_ENABLE=true
# Native mode for NAT servers: srcds listens on public game ports and iptables
# redirects only A2S query packets to the proxy.
L4D2_GO_PROXY_TRANSPARENT_REDIRECT=true
L4D2_GO_PROXY_URL=https://binaries.l4d2node.org/a2s-proxy-go-linux-amd64
L4D2_GO_PROXY_VERSION_URL=https://binaries.l4d2node.org/a2s-proxy-go-linux-amd64.version
L4D2_GO_PROXY_BIN=/usr/local/bin/a2s-proxy-go
L4D2_GO_PROXY_CONFIG=/etc/a2s-proxy-go/config.json
L4D2_GO_PROXY_REDIRECT_BIN=/usr/local/bin/a2s-proxy-redirect.sh
L4D2_GO_PROXY_FORCE_DOWNLOAD=false
# Leave empty to use L4D2_SERVER_IP as backend address.
L4D2_GO_PROXY_BACKEND_IP=
L4D2_GO_PROXY_CACHE_TTL_SECONDS=2
L4D2_GO_PROXY_PLAYER_CACHE_TTL_SECONDS=2
L4D2_GO_PROXY_RULES_CACHE_TTL_SECONDS=10
L4D2_GO_PROXY_SESSION_IDLE_SECONDS=30
L4D2_GO_PROXY_WORKER_COUNT=64
L4D2_GO_PROXY_QUEUE_SIZE=4096
L4D2_GO_PROXY_SOCKET_BUFFER_BYTES=4194304
L4D2_GO_PROXY_MAX_SESSIONS=4096
L4D2_GO_PROXY_MAX_SESSIONS_PER_IP=32
# IP/CIDR entries here bypass A2S cache and query the backend directly.
L4D2_GO_PROXY_BYPASS_CACHE_IPS=
# Allow Anne server browser's "accurate ping" subscription option to bypass A2S cache.
L4D2_GO_PROXY_BYPASS_CACHE_PROBE=true
# Use srcds' native Steam master heartbeat plus iptables SNAT. Keep proxy master registration off.
L4D2_GO_PROXY_MASTER_REGISTER=false
L4D2_GO_PROXY_MASTER_ADDR=
L4D2_GO_PROXY_MASTER_INTERVAL=300
L4D2_GO_PROXY_DEBUG=false
L4D2_GO_PROXY_STATS_INTERVAL=10
L4D2_GO_PROXY_STATS_LOG_FILE=
L4D2_GO_PROXY_STATS_THRESHOLD=100

# Master heartbeat SNAT
L4D2_MASTER_SNAT_ENABLE=false
L4D2_MASTER_SNAT_DEST=hl2master.steampowered.com:27011
L4D2_MASTER_SNAT_BIN=/usr/local/bin/a2s-master-snat.sh

# A2S firewall. "auto" protects the configured game and backend ports.
# You can also use a range/list, for example: "20000:50000" or "12001,12002".
L4D2_A2S_FIREWALL_ENABLE=true
L4D2_A2S_FIREWALL_PORTS=auto
L4D2_A2S_PLAYER_RATE=15/second
L4D2_A2S_PLAYER_BURST=10
L4D2_A2S_INFO_RATE=15/second
L4D2_A2S_INFO_BURST=10
L4D2_A2S_RULES_RATE=10/second
L4D2_A2S_RULES_BURST=5
L4D2_A2S_OTHER_RATE=10/second
L4D2_A2S_OTHER_BURST=5
L4D2_A2S_BAN_SECONDS=60
L4D2_A2S_BAN_HITCOUNT=3
L4D2_A2S_HASH_EXPIRE_MS=60000
L4D2_A2S_LOG_LIMIT=5/min
