{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Anne刷服器",
  "mainBinaryName": "Anne刷服器",
  "version": "1.0.1",
  "identifier": "io.github.competitivewithanne.anne-server-browser",
  "build": {
    "frontendDist": "../tauri-ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Anne刷服器",
        "width": 1280,
        "height": 820,
        "minWidth": 980,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "app", "dmg", "deb", "appimage"],
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ]
  }
}
